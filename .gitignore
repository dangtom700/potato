# ─────────────────────────────────────────────
# MATLAB / Simulink generated code & build cache
# ─────────────────────────────────────────────
slprj/                 # Simulink build cache
*_ert_rtw/             # generated C code folders (lab1_sim_ert_rtw, lab2_sim_ert_rtw, ...)
codegen/
*.slxc                 # Simulink cache
*.asv                  # MATLAB editor autosave
*.autosave
*.m~
*.mex*                 # compiled MEX
*.slx.autosave
*.slx.original
*.slx.bak
*.slx.r20*             # version-specific re-exports (remove this line if you keep them on purpose)
slAccel/
*.slxc.*

# Compiled firmware artifacts (rebuilt by Simulink Coder / PlatformIO)
*.elf
*.hex
*.eep
*.bin
*.o
*.map

# ─────────────────────────────────────────────
# PlatformIO / Arduino  (arduino_code/)
# ─────────────────────────────────────────────
.pio/                  # build output + downloaded libdeps (Unity, etc.)
build/                 # local build folder

# VS Code C/C++ intellisense scratch (machine-specific)
.vscode/ipch/
.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json
.vscode/launch.json

# ─────────────────────────────────────────────
# OS / editor junk
# ─────────────────────────────────────────────
Thumbs.db
desktop.ini
.DS_Store

# ─────────────────────────────────────────────
# Large media (bench photos / video) -- too big for git; store in cloud + link.
# GitHub hard-blocks any file >100 MB, and binaries live in history forever.
# (.png/.jpg are NOT ignored -- report figures and lab photos stay tracked.)
# ─────────────────────────────────────────────
media/
*.mov
*.MOV
*.heic
*.HEIC
